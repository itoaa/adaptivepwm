#!/bin/bash
#
# AdaptivePWM Git Pre-Commit Hook
# CISSP-Aligned Security and Documentation Enforcement
#

echo "====================================="
echo "AdaptivePWM Pre-Commit Hook"
echo "Framework Compliance Check"
echo "====================================="
echo ""

# Get project root
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

cd "$PROJECT_ROOT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Run framework enforcement
if [[ -x "./ci/enforce_framework.sh" ]]; then
    echo "Running framework enforcement..."
    ./ci/enforce_framework.sh
    EXIT_CODE=$?
    
    if [[ $EXIT_CODE -ne 0 ]]; then
        echo ""
        echo -e "${RED}COMMIT BLOCKED${NC}"
        echo "Framework compliance check failed."
        echo "Please fix the issues above before committing."
        exit 1
    fi
else
    echo -e "${YELLOW}Warning: Framework enforcement script not found${NC}"
fi

# Check for hardcoded secrets
echo ""
echo "Checking for hardcoded secrets..."

# Patterns to check
SECRET_PATTERNS=(
    "password\s*="
    "secret\s*="
    "api_key\s*="
    "private_key"
    "BEGIN RSA PRIVATE"
    "BEGIN DSA PRIVATE"
    "token\s*="
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
FOUND_SECRETS=0

for file in $STAGED_FILES; do
    if [[ "$file" =~ \.(c|h|cpp|hpp|py|js|json|md)$ ]]; then
        for pattern in "${SECRET_PATTERNS[@]}"; do
            if git diff --cached "$file" | grep -iE "$pattern" >/dev/null 2>&1; then
                echo -e "${RED}POTENTIAL SECRET in $file:${NC}"
                git diff --cached "$file" | grep -iE "$pattern" | head -3
                FOUND_SECRETS=1
            fi
        done
    fi
done

if [[ $FOUND_SECRETS -eq 1 ]]; then
    echo ""
    echo -e "${RED}COMMIT BLOCKED: Potential secrets found${NC}"
    echo "If these are false positives, use: git commit --no-verify"
    exit 1
fi

# Check if documentation needs update
echo ""
echo "Checking documentation status..."

STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACM | grep "^src/" | wc -l)
STAGED_DOCS=$(git diff --cached --name-only --diff-filter=ACM | grep "^docs/" | wc -l)

if [[ $STAGED_SRC -gt 0 && $STAGED_DOCS -eq 0 ]]; then
    echo -e "${YELLOW}⚠ WARNING: Code changes detected without documentation updates${NC}"
    echo "Framework Requirement 4.3 states that documentation must be updated with code changes."
    echo ""
    echo "Files changed:"
    git diff --cached --name-only | grep "^src/"
    echo ""
    echo "To proceed anyway: git commit --no-verify"
    echo "To update docs: edit docs/ files, then git add docs/"
    
    # Non-blocking warning for now (can be changed to exit 1)
    # exit 1
fi

# Check for large files (>>100KB)
echo ""
echo "Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read f; do
    if [[ -f "$f" ]]; then
        size=$(stat -f%z "$f" 2>/dev/null || stat -c%s "$f" 2>/dev/null)
        if [[ $size -gt 102400 ]]; then
            echo "$f ($((size/1024)) KB)"
        fi
    fi
done)

if [[ -n "$LARGE_FILES" ]]; then
    echo -e "${YELLOW}Large files detected:${NC}"
    echo "$LARGE_FILES"
    echo ""
    echo "Consider using Git LFS for large files."
fi

# Check commit message format (if message file provided)
if [[ -n "$1" && -f "$1" ]]; then
    COMMIT_MSG=$(cat "$1")
    
    # Check conventional commit format
    if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|security|ci)(\(.+\))?: .+"; then
        echo ""
        echo -e "${YELLOW}⚠ WARNING: Commit message doesn't follow conventional format${NC}"
        echo "Expected format: type(scope): subject"
        echo "Types: feat, fix, docs, style, refactor, test, chore, security, ci"
        echo ""
        echo "Example: feat(pwm): add 16MHz HSE clock support"
        echo ""
        echo "Current message:"
        echo "$COMMIT_MSG" | head -1
    fi
fi

echo ""
echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
exit 0
